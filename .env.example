# ============================================================
# Night List — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...  # Safe to expose in client

# ── Stripe ────────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_URL=https://dashboard.nightlist.app
VITE_APP_ENV=production    # development | staging | production

# ============================================================
# SERVER-SIDE ONLY (Supabase Edge Functions secrets)
# Set via: supabase secrets set KEY=value
# ============================================================

# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Set automatically in edge functions
